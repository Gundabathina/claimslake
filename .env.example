# ClaimsLake environment configuration template
# Copy this file to .env and fill in local values. Never commit the real .env file.

# ---- General ----
ENVIRONMENT=local
LOG_LEVEL=INFO

# ---- Object storage (MinIO — local S3-compatible substitute) ----
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_BRONZE=claimslake-bronze
S3_BUCKET_SILVER=claimslake-silver
S3_BUCKET_GOLD=claimslake-gold

# ---- Local analytics warehouse (Postgres) ----
WAREHOUSE_HOST=localhost
WAREHOUSE_PORT=5432
WAREHOUSE_DB=claimslake
WAREHOUSE_USER=claimslake_user
WAREHOUSE_PASSWORD=changeme_local_only

# ---- Airflow ----
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# ---- dbt ----
DBT_PROFILES_DIR=./dbt

# ---- AWS (only needed if deploying the optional Terraform reference architecture) ----
# Use an AWS named profile or environment-based credentials — never hard-code keys here.
AWS_PROFILE=claimslake-dev
AWS_REGION=us-east-1
